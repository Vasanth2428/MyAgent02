# Provider-neutral LLM configuration
# Supported: groq, google_genai (aliases: gemini/google), openai, cerebras
LLM_PROVIDER=groq

# Provider credentials (only the selected provider is required)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_ai_studio_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Override one worker without migrating the rest of the system.
# Worker-specific model names are strongly recommended when changing provider.
# CODING_WORKER_LLM_PROVIDER=google_genai
# CODING_WORKER_MODEL_PRIMARY=gemini-2.5-flash
# CODING_WORKER_MODEL_FALLBACK=gemini-2.5-flash-lite
# Optional cross-provider fallback:
# CODING_WORKER_LLM_FALLBACK_PROVIDER=cerebras
# CODING_WORKER_MODEL_FALLBACK=gpt-oss-120b

# Other supported role prefixes include:
# SUPERVISOR, RAG_WORKER, CODE_CRITIC, CRITIC, SYNTHESIZER,
# REPORT_WORKER, WEB_WORKER, SCRAPER_WORKER, and UTILITY_WORKER.

# Environment variables for Multi-Agent System
TAVILY_API_KEY=your_tavily_api_key_here
SUPERVISOR_MODEL=gpt-4o-mini
REASONING_MODEL=gpt-4o
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
RECURSION_LIMIT=20
CHECKPOINTER_DB_PATH=checkpoints.db
USE_SQLITE_CHECKPOINTER=false

# Weaviate Cloud
WEAVIATE_URL=https://your-cluster.weaviate.network
WEAVIATE_API_KEY=your_weaviate_api_key_here

# HuggingFace — required for server-side vectorization in Weaviate Cloud
# Get a free read token at: https://huggingface.co/settings/tokens
# If absent, Weaviate database operations will fail (local offline fallback degrades to keyword-only search).
HF_API_KEY=hf_your_token_here
